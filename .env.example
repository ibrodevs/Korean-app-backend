# Korean App Backend — Environment Variables
# Copy this file to .env and fill in the values.
# -------------------------------------------------------

# Django core
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave blank (or omit) to use the Docker PostgreSQL service defaults.
DB_NAME=korean_app
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Set USE_SQLITE=True only for local development WITHOUT Docker (rare case).
# In Docker / production always leave this False (PostgreSQL is used).
USE_SQLITE=False

# Redis
REDIS_URL=redis://redis:6379/1

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# CORS (only used when DEBUG=False in production)
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Sentry (Error Tracking)
# Get your DSN from sentry.io
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
